{
  "name": "24h-velo",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"cyan,magenta\" \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix server && npm run build --prefix client",
    "start": "npm start --prefix server",
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "electron:dev": "npm run build && electron electron/main.cjs",
    "electron:pack": "npm run build && npm ci --omit=dev --prefix server && electron-builder --dir && npm install --prefix server",
    "electron:mac": "npm run build && npm ci --omit=dev --prefix server && electron-builder --mac && npm install --prefix server",
    "electron:win": "npm run build && npm ci --omit=dev --prefix server && electron-builder --win && npm install --prefix server"
  },
  "dependencies": {
    "electron-updater": "^6.3.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.24hvelo.dashboard",
    "productName": "24h Vélo",
    "copyright": "24h Vélo Dashboard",
    "main": "electron/main.cjs",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "server/dist",
        "to": "server/dist",
        "filter": ["**/*"]
      },
      {
        "from": "server/public",
        "to": "server/public",
        "filter": ["**/*"]
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*",
          "!**/.bin/**",
          "!**/typescript/**",
          "!**/tsx/**",
          "!**/@types/**",
          "!**/tsconfig*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.sports",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "shortcutName": "24h Vélo"
    },
    "publish": {
      "provider": "github",
      "owner": "mokakokala",
      "repo": "24h-dashboard",
      "releaseType": "release"
    }
  }
}
